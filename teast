local function GetClosestPlayer() local ct, sd = nil, _G.FovRadius for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(_G.TargetPart) and p.Character:FindFirstChildOfClass("Humanoid") and p.Character.Humanoid.Health > 0 then local bp = p.Character[_G.TargetPart] local sp, os = Camera:WorldToViewportPoint(bp.Position) if os then local md = (Vector2.new(sp.X, sp.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude if md < sd then sd, ct = md, bp end end end end return ct end
